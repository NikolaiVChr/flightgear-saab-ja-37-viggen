<?xml version="1.0"?>

<PropertyList>
    <path>altimeter-ja.ac</path>

    <effect>
        <inherits-from>Aircraft/JA37/Models/Effects/ja37-cockpit-transparent-shader</inherits-from>
        <object-name>glass</object-name>
    </effect>

    <effect>
        <inherits-from>Aircraft/JA37/Models/Effects/ja37-cockpit-shader</inherits-from>
        <object-name>mount</object-name>
        <object-name>knob</object-name>
    </effect>
    
    <effect>
        <inherits-from>Aircraft/JA37/Models/Effects/ja37-gauge</inherits-from>
        <object-name>dial</object-name>
        <object-name>flag</object-name>
        <object-name>needle100</object-name>
        <object-name>needle1000</object-name>
        <object-name>baroSTD</object-name>
        <object-name>baro1</object-name>
        <object-name>baro10</object-name>
        <object-name>baro100</object-name>
        <object-name>baro1000</object-name>
    </effect>

    <animation>
        <type>material</type>
        <object-name>dial</object-name>
        <object-name>flag</object-name>
        <object-name>needle100</object-name>
        <object-name>needle1000</object-name>
        <object-name>baroSTD</object-name>
        <object-name>baro1</object-name>
        <object-name>baro10</object-name>
        <object-name>baro100</object-name>
        <object-name>baro1000</object-name>
        <emission>
            <red-prop>instrumentation/instrumentation-light/r</red-prop>
            <green-prop>instrumentation/instrumentation-light/g</green-prop>
            <blue-prop>instrumentation/instrumentation-light/b</blue-prop>
            <factor-prop>controls/lighting/instruments-norm</factor-prop>
        </emission>
    </animation>

    <animation>
        <type>translate</type>
        <object-name>flag</object-name>
        <property>instrumentation/altimeter/power-flag</property>
        <factor>0.01</factor>
        <axis>
          <x>0</x>
          <y>-1</y>
          <z>-1</z>
        </axis>
    </animation>

    <animation>
        <type>pick</type>
        <object-name>mount</object-name>
        <object-name>glass</object-name>
        <hovered>
            <binding>
                <condition>
                    <property>ja37/elec/ac-bus-main-bool</property>
                </condition>
                <command>set-tooltip</command>
                <tooltip-id>altitude</tooltip-id>
                <label>%s</label> <!-- Only one parameter is supported here -->
                <property>/instrumentation/altimeter/indicated-altitude-ft</property>
                <mapping>nasal</mapping>
                <script>
                    return sprintf("Altitude: %d ft / %d m",
                                   getprop("/instrumentation/altimeter/indicated-altitude-ft"),
                                   getprop("/instrumentation/altimeter/indicated-altitude-meter"));
                </script>
            </binding>
        </hovered>
    </animation>

    <animation>
        <type>rotate</type>
        <object-name>needle100</object-name>
        <condition>
            <property>ja37/elec/ac-bus-main-bool</property>
        </condition>
        <property>/instrumentation/altimeter/indicated-altitude-meter</property>
        <factor>0.36</factor>
        <axis>
            <x>-1</x>
            <y>0</y>
            <z>0</z>
        </axis>
    </animation>

    <animation>
        <type>rotate</type>
        <object-name>needle1000</object-name>
        <condition>
            <property>ja37/elec/ac-bus-main-bool</property>
        </condition>
        <property>/instrumentation/altimeter/indicated-altitude-meter</property>
        <factor>0.036</factor>
        <axis>
            <x>-1</x>
            <y>0</y>
            <z>0</z>
        </axis>
    </animation>

    <!-- Pressure Display -->
    <animation>
        <type>translate</type>
        <object-name>baroSTD</object-name>
        <property>/instrumentation/altimeter/std-flag</property>
        <factor>0.013</factor>
        <offset-m>-0.013</offset-m>
        <axis>
          <x>0</x>
          <y>0</y>
          <z>1</z>
        </axis>
    </animation>

    <animation>
        <type>textranslate</type>
        <object-name>baro1000</object-name>
        <property>/instrumentation/altimeter/setting-hpa</property>
        <factor>0.0001</factor>
        <step>1000</step>
        <scroll>1</scroll>
        <axis>
            <x>0</x>
            <y>1</y>
        </axis>
    </animation>

    <animation>
        <type>textranslate</type>
        <object-name>baro100</object-name>
        <property>/instrumentation/altimeter/setting-hpa</property>
        <factor>0.001</factor>
        <step>100</step>
        <scroll>1</scroll>
        <axis>
            <x>0</x>
            <y>1</y>
        </axis>
    </animation>

    <animation>
        <type>textranslate</type>
        <object-name>baro10</object-name>
        <property>/instrumentation/altimeter/setting-hpa</property>
        <factor>0.01</factor>
        <step>10</step>
        <scroll>1</scroll>
        <axis>
            <x>0</x>
            <y>1</y>
        </axis>
    </animation>

    <animation>
        <type>textranslate</type>
        <object-name>baro1</object-name>
        <property>/instrumentation/altimeter/setting-hpa</property>
        <factor>0.1</factor>
        <axis>
            <x>0</x>
            <y>1</y>
        </axis>
    </animation>

    <!--             Altimeter setting       -->
    <animation>
        <type>knob</type>
        <object-name>knob_pick</object-name>
        <action>
            <binding>
                <command>property-adjust</command>
                <property>/instrumentation/altimeter/setting-wheel</property>
                <factor>1</factor>
                <min>0</min>
                <max>360</max>
                <wrap>true</wrap>
            </binding>
            <binding>
                <condition>
                    <not><property>/instrumentation/altimeter/setting-std</property></not>
                </condition>
                <command>property-adjust</command>
                <property>/instrumentation/altimeter/setting-hpa</property>
                <factor>0.25</factor>
                <min>500.0</min>
                <max>1130.0</max>
                <wrap>false</wrap>
           </binding>
        </action>
        <hovered>
            <binding>
                <command>set-tooltip</command>
                <tooltip-id>altimeter-setting</tooltip-id>
                <label>Baro setting: %6.1f hPa</label>
                <property>/instrumentation/altimeter/setting-hpa</property>
            </binding>
        </hovered>
    </animation>

    <animation>
        <type>rotate</type>
        <object-name>knob</object-name>
        <property>/instrumentation/altimeter/setting-wheel</property>
        <center>
          <x-m>0.0</x-m>
          <y-m>0.032</y-m>
          <z-m>-0.032</z-m>
        </center>
        <axis>
          <x>-1</x>
          <y>0</y>
          <z>0</z>
        </axis>
    </animation>

    <animation>
        <type>translate</type>
        <object-name>knob</object-name>
        <object-name>knobPick</object-name>
        <property>/instrumentation/altimeter/std-flag</property>
        <factor>0.005</factor>
        <axis>
            <x>1</x>
            <y>0</y>
            <z>0</z>
        </axis>
    </animation>

    <animation>
        <type>pick</type>
        <object-name>knob</object-name>
        <action>
            <name>STD pressure</name>
            <button>0</button>
            <repeatable>false</repeatable>
            <binding>
                <command>property-toggle</command>
                <property>/instrumentation/altimeter/setting-std</property>
            </binding>
            <binding>
                <condition>
                    <property>/instrumentation/altimeter/setting-std</property>
                </condition>
                <command>property-assign</command>
                <property>/instrumentation/altimeter/setting-hpa-saved</property>
                <property>/instrumentation/altimeter/setting-hpa</property>
            </binding>
            <binding>
                <condition>
                    <property>/instrumentation/altimeter/setting-std</property>
                </condition>
                <command>property-assign</command>
                <property>/instrumentation/altimeter/setting-hpa</property>
                <value>1013</value>
            </binding>
            <binding>
                <condition>
                    <not><property>/instrumentation/altimeter/setting-std</property></not>
                </condition>
                <command>property-assign</command>
                <property>/instrumentation/altimeter/setting-hpa</property>
                <property>/instrumentation/altimeter/setting-hpa-saved</property>
            </binding>
            <binding>
                <command>nasal</command>
                <script>ja37.click()</script>
            </binding>
        </action>
        <hovered>
            <binding>
                <command>set-tooltip</command>
                <tooltip-id>altimeter-std</tooltip-id>
                <label>Toggle STD pressure</label>
            </binding>
        </hovered>
    </animation>
</PropertyList>
